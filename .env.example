# docLlms environment configuration
# Copy to .env and fill in values

# vLLM base URL (default: local, non-docker)
VLLM_BASE_URL=http://localhost:8101

# Which specialist to load at startup (matches id in models/registry.yaml)
DEFAULT_SPECIALIST=pediatrician

# Backend API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=7910

# Frontend Gradio
GRADIO_PORT=7920

# MCP Server
MCP_HOST=127.0.0.1
MCP_PORT=7930
MCP_ENDPOINT=/mcp

# HuggingFace token (for model downloads)
HF_TOKEN=hf_...

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
